rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read their own document, and admins can read any user document.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@anjalkaran.com');
      allow write: if request.auth != null && request.auth.uid == userId;
      // Admins can update/delete any user.
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@anjalkaran.com';
    }

    // Admins can read/write all categories and topics.
    // Authenticated users can read categories and topics.
    match /{collection=categories,topics}/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@anjalkaran.com';
    }

    // Quiz History:
    // Users can create their own quiz history.
    // Users can read their own quiz history.
    // Admins can read all quiz history.
    match /quizHistory/{historyId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@anjalkaran.com');
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admin@anjalkaran.com';
    }
  }
}
