
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: Insecure rules for development. Restrict access before production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read and write access for all authenticated users.
    // This is suitable for development but should be restricted for production.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
