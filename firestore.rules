
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: Insecure rules for development. Restrict access before production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to write to a temporary path for processing
    match /temp-materials/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow anyone to read study materials (adjust for production)
    match /study-materials/{allPaths=**} {
      allow read;
    }
  }
}

    