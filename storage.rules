rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow any authenticated user to write to their own temporary folder.
    match /temp-materials/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow server-side admin to read and delete from any user's temp folder.
      allow read, delete: if true; 
    }
    
    // Allow anyone to read final study materials.
    match /study-materials/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
